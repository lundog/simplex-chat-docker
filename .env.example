# Copy to `.env` and edit. Used by docker-compose and (optionally) the Makefile.

# Published image and tag to run / pull.
IMAGE=lundog/simplex-chat:latest

# Host directory holding the bot's profile + file-exchange dirs.
# /data and /simplex (its `simplex` subpath) are bind-mounted from here onto
# one filesystem. For docker-compose a relative path like ./data is fine;
# for a server you'll likely want an absolute path (e.g. /srv/simplex-volume).
DATA_DIR=./data

# Host TCP port to expose the WebSocket control interface on.
WS_PORT=5225

# Pinned upstream versions baked into the image at build time.
# When bumping these, ALSO refresh the matching SHA-256 build args in the
# Dockerfile from the upstream release pages:
#   simplex-chat: https://github.com/simplex-chat/simplex-chat/releases
#   websocat:     https://github.com/vi/websocat/releases
SIMPLEX_VERSION=v6.5.4
WEBSOCAT_VERSION=v1.14.1
