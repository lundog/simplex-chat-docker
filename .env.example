# Copy to `.env` and edit. Used by docker-compose.

# Published image and tag to run / pull.
IMAGE=lundog/simplex-chat:latest

# Host directory holding the bot's profile and files. Bind-mounted to /data (the
# container's HOME). The profile database and the files/tmp/outbound dirs all
# live under its `.simplex/` subtree on one filesystem. For docker-compose a
# relative path like ./data is fine; for a server you'll likely want an absolute
# path (e.g. /srv/simplex-volume). Sending files is a consumer concern — see
# README "File exchange".
DATA_DIR=./data

# Host TCP port to expose the WebSocket control interface on.
WS_PORT=5225

# Profile display name, applied only on first boot when the profile is created.
PROFILE_DISPLAY_NAME=SimpleX Bot

# Profile type (first boot only). bot = SimpleX bot (peerType "bot"); human =
# plain SimpleX user. Cosmetic — file sharing works either way.
PROFILE_PEER_TYPE=bot

# Custom message relays. Space-separated lists of full server addresses; unset
# = use simplex-chat's public presets. Example:
#   SMP_SERVERS=smp://<fingerprint>@relay1.example smp://<fingerprint>@relay2.example
#   XFTP_SERVERS=xftp://<fingerprint>@relay1.example
#SMP_SERVERS=
#XFTP_SERVERS=

# Note: the simplex-chat / websocat versions and their SHA-256 pins are a
# matched set, bumped together in the Dockerfile — not configured here.
